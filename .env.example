# Velara Care — Environment Variables (copy to .env and fill in)
# ============================================================
# DATABASE_URL — SQLite database file path (relative to prisma/ directory)
DATABASE_URL="file:./dev.db"
#
# NEXTAUTH_SECRET — Used to encrypt JWT tokens. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"
#
# NEXTAUTH_URL — The public URL of your deployment (must match the actual domain)
NEXTAUTH_URL="https://velaracare.co"
